# S4-16 — Variables de entorno para tests E2E con Playwright
# Copia este archivo como .env.e2e y completa los valores reales.
# NUNCA subas .env.e2e al repositorio (ya está en .gitignore).

# URL base de la app (local o staging)
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Cuenta de prueba en el proyecto de staging (wmaafeexiimmrouhpjur)
# Debe tener: 1 empresa configurada con parámetros legales + mínimo 2 empleados activos
E2E_TEST_EMAIL=test@finppi.com
E2E_TEST_PASSWORD=reemplaza_con_password_real

